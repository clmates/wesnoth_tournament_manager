# Frontend API Configuration
# For local development with test backend on port 7100:
VITE_API_BASE_URL=http://localhost:7100/api

# For production (adjust to your deployment URL):
# VITE_API_BASE_URL=https://tournament.wesnoth.org/api

# App Configuration
VITE_APP_NAME=Wesnoth Tournament Manager
VITE_LOG_LEVEL=debug

# WebSocket Configuration
# Set to 'true' to enable real-time notifications via Socket.IO WebSocket
# Set to 'false' to disable (useful when nginx WebSocket forwarding is not configured)
# Default: false (disabled) - notifications will use database fallback
VITE_ENABLE_WEBSOCKETS=false
